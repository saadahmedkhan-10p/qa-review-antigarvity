// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  password           String
  roles              String    @default("[\"REVIEWER\"]")
  passwordResetToken String?
  passwordResetExpiry DateTime?
  ssoProvider        String?
  ssoSubject         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  leadProjects            Project[] @relation("ProjectLead")
  reviewerProjects        Project[] @relation("ProjectReviewer")
  secondaryReviewerProjects Project[] @relation("ProjectSecondaryReviewer")
  contactProjects         Project[] @relation("ProjectContact")
  pmProjects              Project[] @relation("ProjectPM")
  devArchitectProjects    Project[] @relation("ProjectDevArchitect")
  reviews                 Review[]  @relation("PrimaryReviewer")
  secondaryReviews        Review[]  @relation("SecondaryReviewer")
  comments                Comment[]
  notifications           Notification[]

  @@unique([ssoProvider, ssoSubject])
}

model Project {
  id                 String        @id @default(cuid())
  name               String        @unique
  description        String?
  type               String        @default("MANUAL")
  leadId             String?
  reviewerId         String?
  secondaryReviewerId String?
  contactPersonId    String?
  pmId               String?
  devArchitectId     String?
  status             String        @default("ACTIVE")
  closedAt           DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  lead              User?     @relation("ProjectLead", fields: [leadId], references: [id])
  reviewer          User?     @relation("ProjectReviewer", fields: [reviewerId], references: [id])
  secondaryReviewer User?     @relation("ProjectSecondaryReviewer", fields: [secondaryReviewerId], references: [id])
  contactPerson     User?     @relation("ProjectContact", fields: [contactPersonId], references: [id])
  pm                User?     @relation("ProjectPM", fields: [pmId], references: [id])
  devArchitect      User?     @relation("ProjectDevArchitect", fields: [devArchitectId], references: [id])

  reviews Review[]
}

model Form {
  id          String       @id @default(cuid())
  title       String
  questions   String
  projectType String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reviews Review[]
}

model Review {
  id                  String       @id @default(cuid())
  projectId           String
  reviewerId          String
  secondaryReviewerId String?
  formId              String
  status              String       @default("PENDING")
  healthStatus        String       @default("On Track")
  deferredReason      String?
  endedReason         String?
  onHoldReason        String?
  notCompletedReason  String?
  observations        String?
  recommendedActions  String?
  followUpComment     String?
  aiAnalysis          String?
  scheduledDate       DateTime?
  submittedDate       DateTime?
  answers             String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  project           Project   @relation(fields: [projectId], references: [id])
  reviewer          User      @relation("PrimaryReviewer", fields: [reviewerId], references: [id])
  secondaryReviewer User?     @relation("SecondaryReviewer", fields: [secondaryReviewerId], references: [id])
  form              Form      @relation(fields: [formId], references: [id])
  comments          Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  reviewId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  userEmail   String?
  action      String
  entity      String?
  entityId    String?
  projectId   String?
  projectName String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([projectId])
  @@index([createdAt])
}

model SystemSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // e.g., "MENTION", "ASSIGNMENT", "AI_ALERT"
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
